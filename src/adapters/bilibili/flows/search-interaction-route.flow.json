{
  "id": "search-interaction-route",
  "kind": "flow",
  "goal": "Run a Bilibili search interaction flow",
  "steps": [
    {
      "type": "builtin",
      "command": "open",
      "with": {
        "url": "https://www.bilibili.com"
      }
    },
    {
      "type": "builtin",
      "command": "fill",
      "with": {
        "target": {
          "selector": "div:nth-of-type(1) > div:nth-of-type(1) > div:nth-of-type(1) > form:nth-of-type(1) > div:nth-of-type(1) > input:nth-of-type(1)"
        },
        "value": "人工智能"
      }
    },
    {
      "type": "builtin",
      "command": "press",
      "with": {
        "key": "Enter"
      }
    },
    {
      "type": "builtin",
      "command": "open",
      "with": {
        "url": "https://search.bilibili.com/all?keyword=%E4%BA%BA%E5%B7%A5%E6%99%BA%E8%83%BD"
      }
    }
  ],
  "success": [
    {
      "type": "titleNotEmpty"
    }
  ]
}
