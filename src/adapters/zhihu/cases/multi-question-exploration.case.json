{
  "id": "multi-question-exploration",
  "kind": "case",
  "goal": "Verify a Zhihu question page loads correctly.",
  "params": [
    {
      "name": "questionId",
      "type": "string",
      "required": true,
      "description": "Zhihu question ID"
    }
  ],
  "uses": [
    {
      "flow": "explore-multi-question",
      "with": {
        "questionId": "${params.questionId}"
      }
    }
  ],
  "assertions": [
    {
      "type": "urlIncludes",
      "value": "zhihu.com/question"
    }
  ]
}