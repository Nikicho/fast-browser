{
  "id": "zhihu-hot-to-question-direct",
  "kind": "flow",
  "goal": "从知乎热榜页直接打开问题详情页（使用 open URL 方式）",
  "steps": [
    {
      "type": "site",
      "command": "zhihu/hot"
    },
    {
      "type": "site",
      "command": "zhihu/question",
      "with": {
        "questionId": 19581624
      }
    }
  ],
  "success": [
    {
      "type": "urlIncludes",
      "value": "zhihu.com/question"
    },
    {
      "type": "titleNotEmpty"
    }
  ]
}
