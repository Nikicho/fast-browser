{
  "id": "post-login-form-route",
  "kind": "flow",
  "goal": "React Admin post-login list to form workflow",
  "steps": [
    {
      "type": "builtin",
      "command": "open",
      "with": {
        "url": "https://marmelab.com/react-admin-demo/#/products/1/edit"
      }
    },
    {
      "type": "builtin",
      "command": "open",
      "with": {
        "url": "https://marmelab.com/react-admin-demo/#/products/126/show"
      }
    },
    {
      "type": "builtin",
      "command": "open",
      "with": {
        "url": "https://marmelab.com/react-admin-demo/#/customers"
      }
    },
    {
      "type": "builtin",
      "command": "open",
      "with": {
        "url": "https://marmelab.com/react-admin-demo/#/orders"
      }
    },
    {
      "type": "builtin",
      "command": "open",
      "with": {
        "url": "https://marmelab.com/react-admin-demo/#/products/create"
      }
    },
    {
      "type": "builtin",
      "command": "fill",
      "with": {
        "target": {
          "selector": "input:nth-of-type(1)"
        },
        "value": "test-product"
      }
    },
    {
      "type": "builtin",
      "command": "press",
      "with": {
        "key": "Tab"
      }
    },
    {
      "type": "builtin",
      "command": "tabNew",
      "with": {
        "url": "https://marmelab.com/react-admin-demo/#/categories"
      }
    },
    {
      "type": "builtin",
      "command": "tabSwitch",
      "with": {
        "target": "previous"
      }
    }
  ],
  "success": [
    {
      "type": "titleNotEmpty"
    }
  ]
}
