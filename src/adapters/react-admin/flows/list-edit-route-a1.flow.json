{
  "id": "list-edit-route-a1",
  "kind": "flow",
  "goal": "Open React Admin list and edit form",
  "steps": [
    {
      "type": "builtin",
      "command": "open",
      "with": {
        "url": "https://marmelab.com/react-admin-demo/"
      }
    },
    {
      "type": "builtin",
      "command": "fill",
      "with": {
        "target": {
          "selector": "button[aria-label=\"Show password\"]"
        },
        "value": "demo"
      }
    },
    {
      "type": "builtin",
      "command": "fill",
      "with": {
        "target": {
          "selector": "div:nth-of-type(1) > div:nth-of-type(1) > div:nth-of-type(1) > form:nth-of-type(1) > div:nth-of-type(1) > button:nth-of-type(1)"
        },
        "value": "demo"
      }
    },
    {
      "type": "builtin",
      "command": "press",
      "with": {
        "key": "Enter"
      }
    },
    {
      "type": "builtin",
      "command": "wait",
      "with": {
        "ms": 3000
      }
    },
    {
      "type": "builtin",
      "command": "fill",
      "with": {
        "target": {
          "selector": "input[name=username]"
        },
        "value": "demo"
      }
    },
    {
      "type": "builtin",
      "command": "fill",
      "with": {
        "target": {
          "selector": "input[name=password]"
        },
        "value": "demo"
      }
    },
    {
      "type": "builtin",
      "command": "press",
      "with": {
        "key": "Enter"
      }
    },
    {
      "type": "builtin",
      "command": "open",
      "with": {
        "url": "https://marmelab.com/react-admin-demo/#/products"
      }
    },
    {
      "type": "builtin",
      "command": "open",
      "with": {
        "url": "https://marmelab.com/react-admin-demo/#/products/131/show"
      }
    },
    {
      "type": "builtin",
      "command": "open",
      "with": {
        "url": "https://marmelab.com/react-admin-demo/#/products/126"
      }
    },
    {
      "type": "builtin",
      "command": "fill",
      "with": {
        "target": {
          "selector": "input[name=image]"
        },
        "value": "test-image.jpg"
      }
    },
    {
      "type": "builtin",
      "command": "fill",
      "with": {
        "target": {
          "selector": "input[name=thumbnail]"
        },
        "value": "test-thumb.jpg"
      }
    },
    {
      "type": "builtin",
      "command": "tabNew",
      "with": {
        "url": "https://marmelab.com/react-admin-demo/#/products"
      }
    },
    {
      "type": "builtin",
      "command": "tabSwitch",
      "with": {
        "target": "previous"
      }
    },
    {
      "type": "builtin",
      "command": "press",
      "with": {
        "key": "Enter"
      }
    }
  ],
  "success": [
    {
      "type": "titleNotEmpty"
    }
  ]
}
